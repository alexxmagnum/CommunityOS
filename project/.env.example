# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL pública de la app (para enlaces en correos)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Correo transaccional — https://resend.com
# El nombre visible del remitente es el del club que invita (white-label).
# EMAIL_FROM solo define la dirección técnica (dominio verificado en Resend).
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=invitaciones@tudominio.com

# Opcional: clave service role solo en servidor (nunca exponer al cliente)
# Necesaria para recordatorios automáticos de eventos (cron).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secreto para proteger /api/cron/event-reminders (ejecutar cada hora)
# CRON_SECRET=genera-un-secreto-largo
